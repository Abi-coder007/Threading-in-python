   "source": [
    "import threading\n",
    "import time\n",
    "def background_task():\n",
    "    while True:\n",
    "        print(\"Running in background...\")\n",
    "        time.sleep(1)\n",
    "t = threading.Thread(target=background_task,daemon=True)\n",
    "t.start()\n",
    "time.sleep(3)\n",
    "print(\"Main program ended\")"
   ]
